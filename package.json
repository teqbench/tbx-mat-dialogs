{
  "name": "@teqbench/tbx-mat-dialogs",
  "version": "1.0.1",
  "description": "Opinionated Angular modal dialog service built on Material's MatDialog. Severity-leveled methods (success / error / warning / information / help / default) plus dialog-specific UX patterns (confirm / input). Returns Promise<TbxMatDialogResult<T, F>>. Severity colors via @teqbench/tbx-mat-severity-theme; pluggable icons via TBX_MAT_DIALOG_PROVIDER_CONFIG. Angular 21+.",
  "type": "module",
  "exports": {
    "./styles/*": {
      "sass": "./styles/_*.scss"
    }
  },
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "STORYBOOK_MODE=dev storybook dev -p 6006 -c .storybook",
    "storybook:dev": "STORYBOOK_MODE=dev storybook dev -p 6006 -c .storybook",
    "storybook:docs": "STORYBOOK_MODE=docs storybook dev -p 6007 -c .storybook",
    "build-storybook": "STORYBOOK_MODE=dev storybook build -c .storybook -o storybook-dev-static",
    "build-storybook:dev": "STORYBOOK_MODE=dev storybook build -c .storybook -o storybook-dev-static",
    "build-storybook:docs": "STORYBOOK_MODE=docs storybook build -c .storybook -o storybook-docs-static",
    "prepare": "husky"
  },
  "devDependenciesPinned": {
    "//": [
      "typescript-eslint is pinned without ^ because patch releases have historically introduced",
      "breaking rule changes. Pin to a known-good version and update deliberately after testing.",
      "@types/node is pinned to the major version matching the Node runtime (24). Auto-updating",
      "to 25 pulls in type definitions for APIs not available on the target runtime, which can",
      "mask compatibility issues. Re-evaluate when the project moves to the next even-numbered Node LTS."
    ]
  },
  "peerDependencies": {
    "@angular/cdk": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@angular/material": ">=21.0.0",
    "@teqbench/tbx-mat-icons": ">=4.0.0",
    "@teqbench/tbx-mat-severity-theme": ">=8.0.0"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^2.3.1",
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@analogjs/vitest-angular": "^2.3.1",
    "@angular/animations": "^21.2.6",
    "@angular/build": "^21.2.4",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/material": "^21.2.4",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@teqbench/tbx-mat-icons": "^4.2.0",
    "@teqbench/tbx-mat-severity-theme": "^8.0.2",
    "@storybook/angular": "^10.3.3",
    "@types/node": "~24.12.0",
    "@vitest/coverage-v8": "^4.1.1",
    "angular-eslint": "^21.3.1",
    "eslint": "^9.39.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.3.3",
    "ng-packagr": "^21.2.1",
    "prettier": "^3.8.1",
    "storybook": "^10.3.3",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.57.2",
    "vitest": "^4.0.18",
    "zone.js": "^0.16.1"
  },
  "//overrides": "Pin vite to 7.3.2 — @angular/build bundles vite internally but does not constrain the version tightly enough; 7.4+ causes build failures with ng-packagr. Remove when @angular/build supports vite 7.4+. Tracking: https://github.com/teqbench/tbx-mat-dialogs/issues/72.",
  "overrides": {
    "@angular/build": {
      "vite": "7.3.2"
    }
  },
  "lint-staged": {
    "*.{ts,json,md,yml,yaml,scss,css}": [
      "prettier --write"
    ]
  }
}
