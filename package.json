{
  "name": "@teqbench/tbx-mat-dialogs",
  "version": "0.1.1",
  "description": "Opinionated Angular dialog service built on Material dialog. Typed methods for info, warning, error, confirm, and input dialogs returning Promise<DialogOutput<T, F>>. Features emphasis-driven styling, rich footer controls, signal-based input validation via DialogContent, and pluggable icon resolution. Angular 21+.",
  "type": "module",
  "exports": {
    "./styles/*": {
      "sass": "./styles/_*.scss"
    }
  },
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "devDependenciesPinned": {
    "//": [
      "typescript-eslint is pinned without ^ because patch releases have historically introduced",
      "breaking rule changes. Pin to a known-good version and update deliberately after testing.",
      "@types/node is pinned to the major version matching the Node runtime (24). Auto-updating",
      "to 25 pulls in type definitions for APIs not available on the target runtime, which can",
      "mask compatibility issues. Re-evaluate when the project moves to the next even-numbered Node LTS."
    ]
  },
  "peerDependencies": {
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@teqbench/tbx-mat-icons": ">=4.0.0",
    "@teqbench/tbx-mat-severity-theme": ">=8.0.0"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^2.3.1",
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@analogjs/vitest-angular": "^2.3.1",
    "@angular/animations": "^21.2.6",
    "@angular/build": "^21.2.4",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/material": "^21.2.4",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@teqbench/tbx-mat-icons": "^4.2.0",
    "@teqbench/tbx-mat-severity-theme": "^8.0.2",
    "@storybook/angular": "^10.3.3",
    "@types/node": "~24.12.0",
    "@vitest/coverage-v8": "^4.1.1",
    "angular-eslint": "^21.3.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.3.3",
    "ng-packagr": "^21.2.1",
    "prettier": "^3.8.1",
    "storybook": "^10.3.3",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.57.2",
    "vitest": "^4.0.18",
    "zone.js": "^0.16.1"
  },
  "lint-staged": {
    "*.{ts,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
