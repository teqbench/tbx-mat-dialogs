{
  "$schema": "./node_modules/ng-packagr/ng-package.schema.json",
  "dest": "dist",
  "lib": {
    "entryFile": "src/index.ts"
  },
  "assets": [
    "CHANGELOG.md",
    {
      "input": "src/styles",
      "glob": "**/*",
      "output": "styles"
    },
    {
      "input": "docs",
      "glob": "*.{md,yml}",
      "output": "docs"
    }
  ]
}
